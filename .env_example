# ============================================
# Caixa de Perguntas — Environment Variables
# ============================================
# Copy this file to .env.local and fill in the values.
# Do NOT commit .env.local to version control.

# Database
# Local default: ./data/caixa.db
# Azure App Service: /home/data/caixa.db
DATABASE_PATH=./data/caixa.db

# Authentication
# IMPORTANT: Change this to a strong random secret in production
JWT_SECRET=
JWT_EXPIRATION_HOURS=8

# Seed Admin
SEED_ADMIN_USERNAME=admin
SEED_ADMIN_PASSWORD=change-me-first-login

# Rate Limiting
# Window in milliseconds (default: 60000 = 1 minute)
RATE_LIMIT_WINDOW_MS=60000
# Max requests per window per IP hash (default: 5)
RATE_LIMIT_MAX_REQUESTS=5

# Validation
QUESTION_MIN_LENGTH=5
QUESTION_MAX_LENGTH=500